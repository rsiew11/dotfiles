// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette
{
  "agent_servers": {
    "cursor": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    }
  },
  "edit_predictions": {
    "provider": "none",
  },
  "ssh_connections": [
    {
      "host": "deb.box",
      "username": "rei",
      "args": [],
      "projects": [
        {
          "paths": ["/home/rei/dev"],
        },
      ],
    },
  ],
  "agent": {
    "inline_assistant_model": {
      "provider": "google",
      "model": "gemini-3.1-pro-preview",
      "enable_thinking": false
    },
    "default_model": {
      "enable_thinking": true,
      "provider": "google",
      "model": "gemini-3.1-pro-preview",
    },
  },
  "base_keymap": "VSCode",
  "telemetry": {
    "metrics": true,
    "diagnostics": true,
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Gruvbox Dark Soft",
  },
  "terminal": {
    "dock": "right",
  },
  "buffer_font_features": {
    "calt": false,
  },
}
